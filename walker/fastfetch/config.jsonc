      "percent": {
        "green": 50,
        "yellow": 80,
        "type": 0
      },
      "keyIcon": "  ",
      "separate": false
    },

    {
      "type": "host",
      "keyIcon": "󰌢"
    },
    {
      "type": "kernel",
      "keyIcon": ""
    },
        {
